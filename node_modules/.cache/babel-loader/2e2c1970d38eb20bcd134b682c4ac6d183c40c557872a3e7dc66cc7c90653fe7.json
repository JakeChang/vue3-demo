{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  data() {\n    return {\n      texts: [''] // 初始时有一个 textarea\n    };\n  },\n\n  computed: {\n    mergedText() {\n      const nonEmptyTexts = this.texts.filter(text => text.trim() !== ''); // 过滤掉空白的文本框\n      return nonEmptyTexts.join(';'); // 将所有非空白的文本框的内容用分号分隔并合并成一个字符串\n    }\n  },\n\n  methods: {\n    addTextarea() {\n      this.texts.push(''); // 新增一个 textarea\n    },\n\n    removeTextarea(index) {\n      this.texts.splice(index, 1); // 删除指定位置的 textarea\n    },\n\n    confirm() {\n      alert(this.mergedText); // 弹出合并后的字符串\n    }\n  }\n};","map":{"version":3,"names":["data","texts","computed","mergedText","nonEmptyTexts","filter","text","trim","join","methods","addTextarea","push","removeTextarea","index","splice","confirm","alert"],"sources":["/Users/jakechang/Library/CloudStorage/Dropbox/JakeChang/dev/vue3-demo/src/views/FormMultiTextareaView.vue"],"sourcesContent":["<template>\n    <div>\n        <div v-for=\"(text, index) in texts\" :key=\"index\">\n            <textarea v-model=\"texts[index]\"></textarea>\n            <button @click=\"removeTextarea(index)\">删除</button>\n        </div>\n        <button @click=\"addTextarea\">新增 textarea</button>\n        <button @click=\"confirm\">确认</button>\n        <p>{{ mergedText }}</p>\n    </div>\n</template>\n  \n<script>\nexport default {\n    data() {\n        return {\n            texts: [''] // 初始时有一个 textarea\n        }\n    },\n    computed: {\n        mergedText() {\n            const nonEmptyTexts = this.texts.filter(text => text.trim() !== '') // 过滤掉空白的文本框\n            return nonEmptyTexts.join(';') // 将所有非空白的文本框的内容用分号分隔并合并成一个字符串\n        }\n    },\n    methods: {\n        addTextarea() {\n            this.texts.push('') // 新增一个 textarea\n        },\n        removeTextarea(index) {\n            this.texts.splice(index, 1) // 删除指定位置的 textarea\n        },\n        confirm() {\n            alert(this.mergedText) // 弹出合并后的字符串\n        }\n    }\n}\n</script>  "],"mappings":";AAaA,eAAe;EACXA,IAAIA,CAAA,EAAG;IACH,OAAO;MACHC,KAAK,EAAE,CAAC,EAAE,EAAE;IAChB;EACJ,CAAC;;EACDC,QAAQ,EAAE;IACNC,UAAUA,CAAA,EAAG;MACT,MAAMC,aAAY,GAAI,IAAI,CAACH,KAAK,CAACI,MAAM,CAACC,IAAG,IAAKA,IAAI,CAACC,IAAI,EAAC,KAAM,EAAE,GAAE;MACpE,OAAOH,aAAa,CAACI,IAAI,CAAC,GAAG,GAAE;IACnC;EACJ,CAAC;;EACDC,OAAO,EAAE;IACLC,WAAWA,CAAA,EAAG;MACV,IAAI,CAACT,KAAK,CAACU,IAAI,CAAC,EAAE,GAAE;IACxB,CAAC;;IACDC,cAAcA,CAACC,KAAK,EAAE;MAClB,IAAI,CAACZ,KAAK,CAACa,MAAM,CAACD,KAAK,EAAE,CAAC,GAAE;IAChC,CAAC;;IACDE,OAAOA,CAAA,EAAG;MACNC,KAAK,CAAC,IAAI,CAACb,UAAU,GAAE;IAC3B;EACJ;AACJ"},"metadata":{},"sourceType":"module","externalDependencies":[]}